# Rust / Cargo (huge; rebuilt inside container)
microservices/target
**/target

# Git and editor
.git
.gitignore
.cursor
.idea
*.swp
*.swo

# Python
tooling/.venv
.venv
**/__pycache__
**/*.pyc
.pytest_cache
.mypy_cache
.ruff_cache

# Build outputs are excluded by default. Runtime-only service Dockerfiles copy
# an explicitly allow-listed artifact produced by Tilt; do not send the large
# collection of historical/cross-architecture binaries as build context.
build_artifacts/*
!build_artifacts/amd64/
build_artifacts/amd64/*
!build_artifacts/amd64/invoice

# Website / frontend (avoid copying into build context)
ui/website/node_modules
ui/website/dist
**/node_modules

# Env and logs
.env
.env.*
*.log

