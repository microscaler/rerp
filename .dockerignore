# Rust / Cargo (huge; rebuilt inside container)
microservices/target
**/target

# Git and editor
.git
.gitignore
.cursor
.idea
*.swp
*.swo

# Python
tooling/.venv
.venv
**/__pycache__
**/*.pyc
.pytest_cache
.mypy_cache
.ruff_cache

# Service images use a narrow temporary context staged by `rerp docker`; never
# send repository build outputs in base-image or unrelated Docker contexts.
build_artifacts
.docker-context

# Website / frontend (avoid copying into build context)
ui/website/node_modules
ui/website/dist
**/node_modules

# Env and logs
.env
.env.*
*.log
