# Minimal runtime-only Dockerfile for accounting-general-ledger Service (Tilt development)
# Binary is cross-compiled on host and copied in.
# Rendered from this template with: hauliage docker generate-dockerfile <system> <module> [--port N]
# Build with: hauliage docker build-image-simple <image> docker/microservices/Dockerfile.template <hash> <artifact> --service <module>
#
# Multi-arch: buildx sets TARGETARCH (amd64 | arm64 | arm/v7). Defaults for local.

ARG BASE_IMAGE=hauliage-base:latest
FROM ${BASE_IMAGE}

# TARGETARCH: amd64 | arm64 (Apple Silicon) | arm (armv7)
ARG TARGETARCH=amd64
COPY ./build_artifacts/${TARGETARCH}/rerp_accounting_general_ledger_impl /app/rerp_accounting_general_ledger_impl

# Create directories for configuration and assets with write permissions
RUN mkdir -p /app/config /app/doc /app/static_site && chmod -R 777 /app

# Copy configuration and assets (gen: doc/static_site; impl: config)
COPY ./microservices/accounting/general-ledger/impl/config /app/config
COPY ./microservices/accounting/general-ledger/gen/doc /app/doc
COPY ./microservices/accounting/general-ledger/gen/static_site /app/static_site

# Expose HTTP port
EXPOSE 8000

# Runtime environment
ENV RUST_BACKTRACE=1
ENV RUST_LOG=debug

# Run the service via hot-reload hot-runner trap
ENTRYPOINT ["/dev-entrypoint.sh", "/app/rerp_accounting_general_ledger_impl", \
    "--spec", "/app/doc/openapi.yaml", \
    "--doc-dir", "/app/doc", \
    "--static-dir", "/app/static_site", \
    "--config", "/app/config/config.yaml"]
